      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const allRows = $input.all();\nconst sender = $('Code in JavaScript').first().json.sender_email;\nconst subject = $('Email Trigger (IMAP)').first().json.subject?.toLowerCase() || '';\n\nconst knownSubjects = allRows.map(r => r.json.subject?.toLowerCase()).filter(Boolean);\nconst subjectMatch = knownSubjects.some(s => subject.includes(s) || subject.includes('re:'));\n\nif (!subjectMatch) return [];\n\nconst match = $input.all().find(r => r.json.email?.toLowerCase() === sender);\nif (!match) return [];\n\nreturn [{ json: match.json }];\n  \n"
      },
