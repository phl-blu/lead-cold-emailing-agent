      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $input.item.json.from;\nconst match = raw.match(/<(.+?)>/);\nconst sender_email = match ? match[1].toLowerCase() : raw.toLowerCase().trim();\n\nreturn { json: { sender_email } };\n"
      },
